# ── Keep directory structure ────────────────────────────────────────────────
!.gitkeep
!CHECKSUMS.md

# ── R ────────────────────────────────────────────────────────────────────────
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.Rproj
.Renviron

# ── Logs (regenerated each run) ──────────────────────────────────────────────
logs/*.log
logs/session_info.txt

# ── renv (library regenerada via renv::restore()) ─────────────────────────
renv/library/
renv/staging/
renv/sandbox/

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
