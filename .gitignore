# ── Keep directory structure ────────────────────────────────────────────────
!.gitkeep

# ── R ────────────────────────────────────────────────────────────────────────
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.Rproj
.Renviron

# ── Logs (regenerated each run) ──────────────────────────────────────────────
logs/*.log
logs/session_info.txt

# ── STRING cache (large files, auto-downloaded) ──────────────────────────────
data/string_cache/*.gz
data/string_cache/*.txt

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
