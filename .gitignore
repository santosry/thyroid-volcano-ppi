# ── Keep directory structure ────────────────────────────────────────────────
!.gitkeep
!CHECKSUMS.md

# ── R ────────────────────────────────────────────────────────────────────────
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.Rproj
.Renviron

# ── Processed data (regenerated each run) ────────────────────────────────────
data/processed/*
data/string_cache/*

# ── Logs (regenerated each run) ──────────────────────────────────────────────
logs/*.log
logs/session_info.txt

# ── renv (library regenerada via renv::restore()) ─────────────────────────
renv/library/
renv/staging/
renv/sandbox/

# ── Temp files ───────────────────────────────────────────────────────────────
*.pdf.tmp
*.png.tmp
*.tmp

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
