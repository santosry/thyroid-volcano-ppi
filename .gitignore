# ── Keep directory structure ────────────────────────────────────────────────
!.gitkeep

# ── R ────────────────────────────────────────────────────────────────────────
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.Rproj
.Renviron

# ── Generated outputs (regenerated by pipeline) ──────────────────────────────
results/figures/*.png
results/figures/*.pdf
results/figures/*.svg
results/tables/*.tsv
results/network/*.tsv
logs/*.log
logs/session_info.txt

# ── STRING cache (large files, auto-downloaded) ──────────────────────────────
data/string_cache/*.gz
data/string_cache/*.txt

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
